# ============================================
# BACKEND CONFIGURATION
# ============================================
# EQPMGR uses Supabase as the backend
NEXT_PUBLIC_BACKEND_PROVIDER=supabase

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Local development (Docker):
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8001
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxvY2FsIiwicm9sZSI6ImFub24iLCJpYXQiOjE2NzMwMDAwMDAsImV4cCI6MTk4ODYxNjAwMH0.LUC9IfxzLVoUYqHwY83I9_CggdBB2BKcr5z3g8J6N3s
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxvY2FsIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTY3MzAwMDAwMCwiZXhwIjoxOTg4NjE2MDAwfQ.qsJe6sJXeEBNJP3V6yJ2B_pQ7ZrI7z5Z5Z5Z5Z5Z5Z5

# ============================================
# AI / OPENAI CONFIGURATION
# ============================================
# OpenAI API key for AI features
# Used for component recognition, vector embeddings, chat, etc.
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ============================================
# EMAIL CONFIGURATION
# ============================================
# SMTP settings for sending emails (verification, notifications, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================

# Strava API (for activity imports)
NEXT_PUBLIC_STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# MapMyRide API (for activity imports)
MAPMYRIDE_CLIENT_ID=your_mapmyride_client_id
MAPMYRIDE_CLIENT_SECRET=your_mapmyride_client_secret

# OpenWeather API (for weather data)
OPENWEATHER_API_KEY=your_openweather_api_key

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================
# Base URL for your deployed application (used for OAuth redirects, etc.)
NEXT_PUBLIC_BASE_URL=https://your-app.netlify.app

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
# Set to 'development' or 'production'
NODE_ENV=development

# ============================================
# BACKEND SWITCHING GUIDE
# ============================================
#
# To switch from Firebase to Supabase:
# 1. Set NEXT_PUBLIC_BACKEND_PROVIDER=supabase
# 2. Ensure all SUPABASE_* variables are set
# 3. Run npm run build
# 4. Deploy
#
# To switch back to Firebase:
# 1. Set NEXT_PUBLIC_BACKEND_PROVIDER=firebase
# 2. Ensure all FIREBASE_* variables are set
# 3. Run npm run build
# 4. Deploy
#
# The application code remains the same - only the environment variable changes!
#
# ============================================
