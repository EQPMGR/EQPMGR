  const snapshot = await adminDb.collection(collectionName).get();
  const data = snapshot.docs.map(doc => ({
    id: doc.id,
    ...doc.data()
  }));

  fs.writeFileSync(
    `./migration-data/${collectionName}.json`,
    JSON.stringify(data, null, 2)
  );
